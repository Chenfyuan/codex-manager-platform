{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Codex Manager",
  "version": "0.1.0",
  "identifier": "com.codex-manager.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex 管理平台",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 22 },
        "transparent": true,
        "visible": true,
        "windowEffects": {
          "effects": ["sidebar", "mica"],
          "state": "followsWindowActiveState",
          "radius": 10
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:*; style-src 'self' 'unsafe-inline'"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["SimpChinese", "English"]
      }
    },
    "shortDescription": "多账号 Codex 编程代理管理平台",
    "longDescription": "管理多个 OpenAI Codex 编程代理账号，支持 API Key 和 OAuth 认证，实时任务监控，会话历史持久化。",
    "category": "DeveloperTool",
    "copyright": "Copyright 2026",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Chenfyuan/codex-manager-platform/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzQjEzMDcyNjZBMzhEMDIKUldRQ2phTm1jakN4STlIZExFYUFlU0pQSzlORFVEZVV4MmVKNkw5My8zdnlSTEt1dVNzdlNiSk4K"
    }
  }
}
